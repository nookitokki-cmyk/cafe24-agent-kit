{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nookitokki.co.kr/schemas/cafe24-brand-profile.schema.json",
  "title": "카페24 Brand Profile",
  "description": "클라이언트별 통합 프로필 (메타·연락처·프로젝트·브랜드·페이지 구성·디자인 토큰 참조). brand-profile.json 파일의 검증 기준.",
  "type": "object",
  "required": ["client", "platform", "brand"],
  "additionalProperties": false,
  "properties": {
    "client": {
      "type": "string",
      "description": "클라이언트 식별자 (영문 소문자 kebab-case). 폴더명과 일치해야 함.",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "platform": {
      "type": "string",
      "enum": ["cafe24", "imweb", "sixshop"],
      "description": "쇼핑몰 플랫폼"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0",
      "description": "프로필 버전 (스코프/톤 변경 등 의미 있는 수정 시 증가)"
    },

    "contact": {
      "type": "object",
      "description": "클라이언트 연락처. contract-maker / client-writer 자동 참조.",
      "additionalProperties": false,
      "properties": {
        "company": { "type": "string", "description": "회사명/상호" },
        "person": { "type": "string", "description": "담당자 이름" },
        "role": { "type": "string", "description": "담당자 직책 (예: 대표, 마케팅 팀장)" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string", "description": "010-0000-0000 형식" },
        "kakao_id": { "type": "string" },
        "business_no": { "type": "string", "description": "사업자등록번호" }
      }
    },

    "project": {
      "type": "object",
      "description": "프로젝트 정보",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "description": "프로젝트명 (예: 쇼핑몰 리뉴얼, 모바일 페이지 작업)" },
        "start_date": { "type": "string", "format": "date" },
        "deadline": { "type": "string", "format": "date" },
        "status": {
          "type": "string",
          "enum": ["onboarding", "design", "implementation", "review", "deployed", "maintenance", "completed", "paused"],
          "description": "현재 단계"
        },
        "budget": { "type": "string", "description": "(선택) 견적 금액 메모" },
        "tally_submission_id": { "type": "string", "description": "Tally 폼 제출 ID (있으면)" },
        "notion_doc_url": { "type": "string", "format": "uri", "description": "관련 노션 문서 URL" }
      }
    },

    "platform_detail": {
      "type": "object",
      "description": "카페24 특화 정보 (deploy-assistant·cafe24-ez 참조)",
      "additionalProperties": false,
      "properties": {
        "mall_id": { "type": "string", "description": "카페24 몰 ID (예: demo-brand)" },
        "skin_code": { "type": "string", "description": "작업 베이스 스킨 (예: 2, 5)" },
        "editor_type": {
          "type": "string",
          "enum": ["H", "E"],
          "description": "H=HTML 방식, E=EZ 비주얼 에디터"
        },
        "ftp_configured": { "type": "boolean", "description": "FTP/SFTP 접속 설정 완료 여부" },
        "mobile_web_disabled": { "type": "boolean", "description": "관리자 '모바일 전용 디자인 사용설정' 해제 여부" }
      }
    },

    "brand": {
      "type": "object",
      "required": ["tone"],
      "description": "브랜드 정체성. 모든 카피·디자인 결정의 가이드.",
      "additionalProperties": false,
      "properties": {
        "tone": {
          "type": "string",
          "description": "한 줄 톤 (예: '럭셔리 미니멀 — 절제된 톤, 여백 강조')"
        },
        "voice": {
          "type": "string",
          "description": "메시지 보이스 (예: '차분하고 정중함', '발랄한 친근감')"
        },
        "target": {
          "type": "string",
          "description": "타깃 페르소나 (예: '30-50대 여성, 안티에이징 관심')"
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "브랜드 키워드 3-5개"
        },
        "do_say": {
          "type": "array",
          "items": { "type": "string" },
          "description": "권장 표현 / 어휘"
        },
        "dont_say": {
          "type": "array",
          "items": { "type": "string" },
          "description": "금지 표현 (경쟁사명·민감 어휘 등)"
        }
      }
    },

    "design_tokens": {
      "type": "string",
      "default": "./design-tokens.json",
      "description": "design-tokens.json 파일의 상대 경로 (보통 같은 폴더)"
    },

    "pages": {
      "type": "array",
      "description": "작업 대상 페이지 목록",
      "items": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["hero-main", "plp-full", "pdp-full", "narrow", "board"],
            "description": "페이지 타입 (templates/{type}.html 매핑)"
          },
          "path": { "type": "string", "description": "URL 경로 (예: /, /product/list)" },
          "name": { "type": "string", "description": "표시명 (예: 메인, 상품 목록)" },
          "status": {
            "type": "string",
            "enum": ["pending", "design", "implementation", "review", "deployed"],
            "default": "pending"
          },
          "figma_node": { "type": "string", "description": "Figma 노드 ID (있으면)" },
          "notes": { "type": "string" }
        }
      }
    },

    "constraints": {
      "type": "object",
      "description": "디자인·코딩 제약 (누끼토끼 표준 기본값 + 클라이언트 오버라이드)",
      "additionalProperties": false,
      "properties": {
        "font": { "type": "string", "default": "Pretendard" },
        "icon": { "type": "string", "default": "Phosphor" },
        "css_prefix": { "type": "string", "default": "nk-", "pattern": "^[a-z]+-$" },
        "no_italic": { "type": "boolean", "default": true },
        "breakpoints": {
          "type": "array",
          "items": { "type": "string", "pattern": "^\\d+px$" },
          "default": ["375px", "768px", "1280px", "1440px"]
        },
        "max_width": { "type": "string", "description": "콘텐츠 최대 너비 (별도 지시 없으면 미설정)" }
      }
    },

    "social": {
      "type": "object",
      "description": "(선택) 클라이언트 SNS 정보",
      "additionalProperties": false,
      "properties": {
        "instagram": { "type": "string" },
        "youtube": { "type": "string" },
        "naver_blog": { "type": "string" },
        "homepage": { "type": "string", "format": "uri" }
      }
    },

    "history": {
      "type": "array",
      "description": "주요 작업 이력 (자세한 로그는 05_work-log.md)",
      "items": {
        "type": "object",
        "required": ["date", "action"],
        "additionalProperties": false,
        "properties": {
          "date": { "type": "string", "format": "date" },
          "action": { "type": "string", "description": "한 줄 요약" },
          "by": { "type": "string", "description": "(선택) 작업 주체 (사용자 / 에이전트명)" },
          "diff": { "type": "string", "description": "(선택) 변경 내용 요약" }
        }
      }
    },

    "notes": {
      "type": "string",
      "description": "기타 메모. 에이전트가 무시하지만 사람이 참고용."
    }
  }
}
