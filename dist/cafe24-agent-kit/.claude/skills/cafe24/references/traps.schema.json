{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cafe24 traps catalog",
  "description": "카페24 base 오버라이드 함정 머신리더블 카탈로그 스키마",
  "type": "object",
  "required": ["version", "traps"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "updated": { "type": "string" },
    "description": { "type": "string" },
    "legend": { "type": "object" },
    "traps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "scope", "severity", "symptom", "detectable", "fixCSS", "source"],
        "properties": {
          "id": { "type": "string", "description": "F번호 또는 코드 (예: F10, S1, FONT)" },
          "name": { "type": "string" },
          "grade": { "type": "string", "enum": ["green", "yellow", "white"], "description": "출처 등급" },
          "scope": { "type": "string", "enum": ["global", "layout", "header", "footer", "component", "form", "build", "deploy", "network", "method"] },
          "method": { "type": "string", "enum": ["html-native", "ez-on-legacy", "both"], "description": "어느 작업 방식에서 발생하나. 없으면 both 로 간주. ez-on-legacy = EZ 엎기 전용. skin-method-detect.md 참조" },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] },
          "layer": { "type": "string", "description": "이 함정이 사는 곳 (base 파일/EZ/우리 규칙 등)" },
          "symptom": { "type": "string", "description": "사람이 보는 증상" },
          "rootCause": { "type": "string", "description": "근본 원인" },
          "detectable": { "type": "string", "enum": ["runtime", "static", "network", "manual"] },
          "detectJS": { "type": ["string", "null"], "description": "라이브 DOM 에서 실행할 탐지 함수 본문. {hit, detail} 반환 또는 falsy. runtime 만 채움" },
          "fixCSS": { "type": "string", "description": "처방. SKIN 은 실제 #nk-skin{번호} 로 치환" },
          "source": { "type": "string", "description": "산문 원본 위치" }
        }
      }
    }
  }
}
