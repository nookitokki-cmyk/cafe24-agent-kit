{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cafe24 Component Gallery — 항목 체크리스트",
  "description": "컴포넌트 갤러리(준비물 ②)가 갖춰야 할 필수 구성. example-gallery.html이 이 스키마를 만족하는지 점검용.",
  "type": "object",
  "required": ["client", "css_refs", "sections"],
  "properties": {
    "client": {
      "type": "string",
      "description": "클라이언트 몰 이름 또는 몰ID (예: MURMUR)"
    },
    "css_refs": {
      "type": "object",
      "description": "갤러리가 불러오는 정본 CSS 2종 경로. 갤러리 자체는 컴포넌트 스타일을 정의하지 않는다.",
      "required": ["tokens", "components"],
      "properties": {
        "tokens": {
          "type": "string",
          "description": "준비물 ① 값 — nk-tokens.css 경로",
          "pattern": "nk-tokens\\.css$"
        },
        "components": {
          "type": "string",
          "description": "준비물 ② 부품 — nk-components.css 경로",
          "pattern": "nk-components\\.css$"
        }
      }
    },
    "fonts": {
      "type": "array",
      "description": "폰트 CDN. 지시 없으면 Pretendard + Phosphor 기본.",
      "items": { "type": "string" },
      "default": ["Pretendard", "Phosphor Icons"]
    },
    "sections": {
      "type": "array",
      "description": "갤러리 섹션 목록. 아래 필수 섹션(required_sections)을 모두 포함해야 한다.",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": ["key", "title", "components"],
        "properties": {
          "key": { "type": "string" },
          "title": { "type": "string" },
          "components": {
            "type": "array",
            "description": "이 섹션이 진열하는 nk-* 컴포넌트 클래스 목록",
            "items": { "type": "string", "pattern": "^nk-" }
          }
        }
      }
    }
  },
  "required_sections": {
    "description": "몰 종류와 무관하게 최소로 갖춰야 할 컴포넌트 카테고리",
    "palette":  "토큰 색상 스와치",
    "buttons":  ".nk-btn (variant · size · block · disabled)",
    "form":     ".nk-field · .nk-form-row · 체크/라디오 (로그인·회원가입 조립용)",
    "cards":    ".nk-card · .nk-prd-card (상품 진열용)",
    "data":     ".nk-dl · .nk-table (주문/회원 정보)",
    "nav_feedback": ".nk-tabs · .nk-badge · .nk-pagination · .nk-empty"
  },
  "rules": {
    "prefix_component": "nk-",
    "prefix_scaffold": "gx-",
    "no_inline_component_style": "컴포넌트 스타일은 nk-components.css에만. 갤러리 HTML엔 진열용 gx-*만.",
    "no_mockup": "실제 작동하는 CSS로 렌더된 실물만. 가짜 스크린샷/플레이스홀더 금지."
  }
}
