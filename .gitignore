# Secrets — never commit
mcp/config/cafe24_config_*.py
!mcp/config/cafe24_config.example.py
mcp/config/*.token.json
mcp/config/sftp_*.json

# Local work / backups
mcp/backups/
mcp/work/clients/
work/deploy-*/
# 클라이언트 폴더: _template·demo000(예시)만 추적, 나머지 실/테스트 클라는 전부 제외
agent-kit/clients/*
!agent-kit/clients/_template/
!agent-kit/clients/demo000/
**/.vscode/sftp.json

# api-poc 보존 자산은 설계서·PoC만 (실제 비밀 설정/토큰은 추적 금지)
api-poc/cafe24_config.py
api-poc/*.token.json
api-poc/auth_url.txt

# Build artifacts (Release asset only)
dist/
cafe24-agent-kit-v*/
cafe24-agent-kit-v*.zip

# Dev session state
.omc/

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# Env
.env
.env.local

# OS / IDE
.DS_Store
Thumbs.db
*.swp
.cursor/mcp.json
.mcp.json

# 키트 내부 보관 (배포·git 추적 제외)
_archive/
