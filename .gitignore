# Secrets — never commit
mcp/config/cafe24_config_*.py
!mcp/config/cafe24_config.example.py
mcp/config/*.token.json
mcp/config/sftp_*.json

# Local work / backups
mcp/backups/
mcp/work/clients/
work/deploy-*/
# 루트 스크린샷·측정 JSON 스크래치 (몰ID 접두사) — 클라이언트 작업물은 키트 밖(C:\nookitokki\clients\)에 보관
/ecudemo*-*.png
/ecudemo*-*.json
/ecudemo*-*.md
/ref*-*.json
/target*-*.json

# Node deps / browser automation 산출물 — 절대 커밋 금지
node_modules/
.playwright-mcp/
web/cafe24/.Codex/
# 클라이언트 폴더: _template·demo000(예시)·_verified-template(검증 템플릿)만 추적, 나머지 실/테스트 클라는 전부 제외
agent-kit/clients/*
!agent-kit/clients/_template/
!agent-kit/clients/demo000/
!agent-kit/clients/_verified-template/
**/.vscode/sftp.json

# api-poc 보존 자산은 설계서·PoC만 (실제 비밀 설정/토큰은 추적 금지)
api-poc/cafe24_config.py
api-poc/*.token.json
api-poc/auth_url.txt

# Build artifacts (Release asset only)
dist/
cafe24-agent-kit-v*/
cafe24-agent-kit-v*.zip

# Dev session state
.omc/

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# Env
.env
.env.local

# OS / IDE
.DS_Store
Thumbs.db
*.swp
.cursor/mcp.json
.mcp.json

